{
  "name": "verifylearn-backend",
  "version": "1.0.0",
  "description": "Core API and Gateway for VerifyLearn Ecosystem",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "build:css": "tailwindcss -i ./public/styles/input.css -o ./public/styles/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./public/styles/input.css -o ./public/styles/tailwind.css --watch",
    "dev": "concurrently \"npm run watch:css\" \"node src/app.js\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "ethers": "^6.17.0",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "tailwindcss": "^3.4.0"
  }
}
